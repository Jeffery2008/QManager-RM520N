#!/bin/sh
# =============================================================================
# qmanager_setup — One-Shot Directory & Permission Setup (RM520N-GL)
# =============================================================================
# One-shot setup: creates directories, sets permissions, initializes config.
# Run once at boot by qmanager-setup.service before other services start.
#
# Install location: /usr/bin/qmanager_setup
# =============================================================================

# Remount root filesystem read-write if needed (RM520N-GL boots read-only)
if ! touch /usr/.qm_rw_test 2>/dev/null; then
    mount -o remount,rw / 2>/dev/null
fi
rm -f /usr/.qm_rw_test

# Ensure required directories exist
mkdir -p /var/lock /etc/qmanager /usr/lib/qmanager /tmp/quecmanager /var/spool/cron/crontabs
# CGI (www-data) writes cron entries for root — needs write access to spool dir
chmod 777 /var/spool/cron/crontabs

# AT device permissions — www-data (via dialout group) needs read/write access
# /dev/smd11 defaults to crw------- root:root; must open it to dialout group
if [ -e /dev/smd11 ]; then
    chown root:dialout /dev/smd11
    chmod 660 /dev/smd11
fi

# Shared /tmp files — pre-created with correct ownership for fs.protected_regular=1.
# CRITICAL: RM520N-GL's sticky /tmp + protected_regular blocks O_CREAT and open-for-write
# unless file_owner==caller OR dir_owner==caller (root owns /tmp).
# Must match paths in /usr/bin/qcmd: LOCK_FILE and PID_FILE
#
# Strategy: files written by BOTH root (poller) and www-data (CGI) must be root-owned
# with mode 666. Files written by www-data only are www-data-owned.
touch /tmp/qmanager_at.lock /tmp/qmanager_at.pid \
      /tmp/qmanager_profile_apply.pid /tmp/qmanager_profile_state.json
chown www-data:www-data /tmp/qmanager_at.lock /tmp/qmanager_at.pid \
      /tmp/qmanager_profile_apply.pid /tmp/qmanager_profile_state.json
chmod 666 /tmp/qmanager_at.lock /tmp/qmanager_at.pid \
      /tmp/qmanager_profile_apply.pid /tmp/qmanager_profile_state.json

# Shared root-owned files — both root (poller/daemons) and www-data (CGI) write.
# If www-data owned these, root would be blocked by fs.protected_regular=1.
touch /tmp/qmanager.log
chown root:root /tmp/qmanager.log
chmod 666 /tmp/qmanager.log

# Session directory — www-data needs write access (cleared on reboot since /tmp is tmpfs)
mkdir -p /tmp/qmanager_sessions
chown www-data:www-data /tmp/qmanager_sessions
chmod 700 /tmp/qmanager_sessions

# Config directory — www-data needs write access for auth.json, profiles
chown -R www-data:www-data /etc/qmanager

# Make all qmanager binaries executable
for f in /usr/bin/qmanager_*; do
    [ -f "$f" ] && chmod +x "$f"
done

# Make all CGI scripts executable
CGI_DIR="/usrdata/qmanager/www/cgi-bin/quecmanager"
for f in "$CGI_DIR"/*.sh "$CGI_DIR"/*/*.sh; do
    [ -f "$f" ] && chmod +x "$f"
done

# Tailscale directory — tailscaled resets its state dir to 700 on start;
# www-data CGI needs traverse+read to check if binaries exist
if [ -d /usrdata/tailscale ]; then
    chmod 755 /usrdata/tailscale
fi

# Secure auth config
[ -f /etc/qmanager/auth.json ] && chmod 600 /etc/qmanager/auth.json

# Create default long_commands.list if missing
if [ ! -f /etc/qmanager/long_commands.list ]; then
    cat > /etc/qmanager/long_commands.list << 'EOF'
# QManager Long Commands List
QSCAN
QSCANFREQ
QFOTADL
EOF
fi

# Initialize default JSON config if missing
if [ -f /usr/lib/qmanager/config.sh ]; then
    . /usr/lib/qmanager/config.sh
    qm_config_init
fi
